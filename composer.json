{
  "repositories": [
    {
      "type": "path",
      "url": "/home/venom/projects/composer/xwp/plugin-settings-api",
      "canonical": true,
      "options": {
        "symlink": true,
        "versions": {
          "x-wp/plugin-settings-api": "1.0.0"
        }
      }
    }
  ],
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "automattic/jetpack-autoloader": "^5.0",
    "oblak/transliterator": "^2.0",
    "oblak/wp-plugin-installer": "^2.1",
    "symfony/css-selector": "^5.4",
    "voku/simple_html_dom": "^4.8",
    "wptechnix/wp-settings-builder": "^1.0",
    "x-wp/di": "^1.7"
  },
  "require-dev": {
    "oblak/wordpress-coding-standard": "^1.2",
    "php-stubs/wordpress-stubs": "^6.5",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan": "^1.10",
    "phpstan/phpstan-deprecation-rules": "^1.1",
    "wp-cli/wp-cli": "^2.12",
    "phpunit/phpunit": "^9.6",
    "swissspidy/phpstan-no-private": "^0.2.0",
    "symfony/var-dumper": "^6.4",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "x-wp/whoops": "^1.0",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Oblak\\STL\\": "lib",
      "STL\\Common\\": "src/Common/",
      "STL\\": "src/Modules/"
    },
    "classmap": [
      "src/App.php",
      "lib/"
    ]
  },
  "config": {
    "platform": {
      "php": "8.1"
    },
    "allow-plugins": {
      "automattic/jetpack-autoloader": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:clean": "bash bin/clean-wp-tests.sh",
    "test:env:start": "docker compose up -d mysql",
    "test:env:stop": "docker compose down --remove-orphans",
    "test:install": [
      "@test:env:start",
      "bash bin/install-wp-tests.sh"
    ]
  }
}
